# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# These env vars are injected at container runtime.
# Do NOT commit .env.docker to version control.

# Required
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — used as fallback aliases
PUBLIC_SUPABASE_ANON_KEY=

# Upstash Redis (optional — for production caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# TMDB (at least one required)
TMDB_API_KEY=
TMDB_ACCESS_TOKEN=

# Cloudflare (optional — for local preview with remote resources)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKERS_SUBDOMAIN=
