---
export interface Props {
  currentPage: number;
  totalPages: number;
  buildPageHref: (page: number) => string;
}

const { currentPage, totalPages, buildPageHref } = Astro.props;

function getPageNumbers(current: number, total: number): (number | string)[] {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }

  const pages: (number | string)[] = [];
  pages.push(1);

  const windowStart = Math.max(2, current - 2);
  const windowEnd = Math.min(total - 1, current + 2);

  if (windowStart > 2) {
    if (windowStart > 3) {
      pages.push('...');
    } else {
      pages.push(2);
    }
  }

  for (let i = windowStart; i <= windowEnd; i++) {
    pages.push(i);
  }

  if (windowEnd < total - 1) {
    if (windowEnd < total - 2) {
      pages.push('...');
    } else {
      pages.push(total - 1);
    }
  }

  pages.push(total);

  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
const linkClass = 'inline-flex items-center justify-center w-9 h-9 text-sm font-medium rounded-pill transition-all';
const activeClass = 'bg-ink text-canvas';
const inactiveClass = 'text-link hover:bg-hairline';
const disabledClass = 'pointer-events-none opacity-40';
const ellipsisClass = 'inline-flex items-center justify-center w-9 h-9 text-sm text-mute select-none';
---

{
  totalPages > 1 && (

    <nav class="mt-10 flex items-center justify-center gap-1 border-t border-hairline pt-6" aria-label="Pagination">

      <a
        href={buildPageHref(currentPage - 1)}
        class:list={['text-sm font-medium text-link hover:underline mr-2', currentPage <= 1 && disabledClass]}
        aria-label="Previous page"
      >
        Previous
      </a>

      <div class="flex items-center gap-0.5">
        {pageNumbers.map((page) =>
          page === '...' ? (
            <span class={ellipsisClass}>&hellip;</span>
          ) : (
            <a
              href={buildPageHref(page as number)}
              class:list={[linkClass, page === currentPage ? activeClass : inactiveClass]}
              aria-current={page === currentPage ? 'page' : undefined}
              aria-label={`Page ${page}`}
            >
              {page}
            </a>
          )
        )}
      </div>

      <a
        href={buildPageHref(currentPage + 1)}
        class:list={['text-sm font-medium text-link hover:underline ml-2', currentPage >= totalPages && disabledClass]}
        aria-label="Next page"
      >
        Next
      </a>
    </nav>
  )
}
