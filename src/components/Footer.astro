---
import { REGIONS, GENRES, OTT_PLATFORMS } from '../data/movies';

const currentYear = new Date().getFullYear();
---

<footer class="bg-canvas border-t border-hairline py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-5">
      <div class="col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 group">
          <span class="brand-logo-icon flex h-8 w-8 items-center justify-center rounded-premium overflow-hidden bg-ink text-canvas" style="border-radius: 14px;" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4.4 10.25H19.6V17.25C19.6 18.05 18.95 18.7 18.15 18.7H5.85C5.05 18.7 4.4 18.05 4.4 17.25V10.25Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M4.2 10.25L3.65 7.15C3.5 6.35 4.02 5.58 4.82 5.43L16.85 3.2C17.65 3.05 18.42 3.58 18.57 4.38L19.1 7.2L4.2 10.25Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M7.2 4.98L9.95 8.98" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <path d="M11.95 4.1L14.7 8.02" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <path d="M16.45 3.27L18.98 6.88" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
          <span class="text-base font-semibold tracking-tight text-ink">Free Movie Suggestion</span>
        </a>
        <p class="mt-4 text-sm text-body leading-relaxed max-w-xs">
          The ultimate suggestion engine for Bollywood, Hollywood, and Tollywood movies. Find where to watch your next favorite story.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-mono font-medium uppercase tracking-widest text-mute">Regions</h3>
        <ul class="mt-4 space-y-2">
          {REGIONS.map(region => (
            <li>
              <a href={`/region/${region.toLowerCase()}`} class="text-sm text-body hover:text-ink transition-colors">
                {region}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-mono font-medium uppercase tracking-widest text-mute">Top Genres</h3>
        <ul class="mt-4 space-y-2">
          {GENRES.slice(0, 6).map(genre => (
            <li>
              <a href={`/genre/${genre.toLowerCase()}`} class="text-sm text-body hover:text-ink transition-colors">
                {genre}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-mono font-medium uppercase tracking-widest text-mute">OTT Platforms</h3>
        <ul class="mt-4 space-y-2">
          {OTT_PLATFORMS.slice(0, 6).map(ott => (
            <li>
              <a href={`/ott/${ott.name.toLowerCase().replace('+', 'plus').replace(' ', '-')}`} class="text-sm text-body hover:text-ink transition-colors">
                {ott.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-2 md:col-span-1">
        <h3 class="text-xs font-mono font-medium uppercase tracking-widest text-mute">Resources</h3>
        <ul class="mt-4 space-y-2">
          <li>
            <a href="/movies" class="text-sm text-body hover:text-ink transition-colors">
              All Movies
            </a>
          </li>
          <li>
            <a href="/about" class="text-sm text-body hover:text-ink transition-colors">
              About Us
            </a>
          </li>
          <li>
            <a href="/contact" class="text-sm text-body hover:text-ink transition-colors">
              Contact Us
            </a>
          </li>
          <li>
            <a href="/privacy" class="text-sm text-body hover:text-ink transition-colors">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/terms" class="text-sm text-body hover:text-ink transition-colors">
              Terms & Conditions
            </a>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="mt-16 border-t border-hairline pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-mute">
        © {currentYear} Free Movie Suggestion. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="https://twitter.com" class="text-mute hover:text-ink transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
        </a>
        <a href="https://github.com" class="text-mute hover:text-ink transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
