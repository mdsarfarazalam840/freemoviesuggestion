---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MovieCardAstro from '../components/MovieCard.astro';
import Footer from '../components/Footer.astro';
import { searchMovies } from '../services/movieService';

export const prerender = false;

const query = Astro.url.searchParams.get('q') || '';
let movies: any[] = [];
let count = 0;

if (query) {
  try {
    const result = await searchMovies(query, { page: 1, limit: 24 });
    movies = result.movies || [];
    count = result.count || 0;
  } catch (error) {
    console.error('[search.astro] Error:', error);
    movies = [];
    count = 0;
  }
}
---

<Layout title={query ? `Search: ${query}` : 'Search Movies'}>
  <Navbar />
  <main class="min-h-screen bg-canvas-soft py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-ink">
          {query ? `Results for "${query}"` : 'Search Movies'}
          {query && <span class="ml-2 text-sm font-normal text-mute">({count} results)</span>}
        </h1>
      </div>

      <div class="mb-10 max-w-xl">
        <form action="/search" method="GET" class="relative group">
          <button type="submit" class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-mute hover:text-link transition-colors z-10" aria-label="Search">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
          <input
            type="text"
            name="q"
            value={query}
            placeholder="Search movies..."
            class="w-full h-14 pl-12 pr-28 rounded-premium border border-hairline bg-canvas text-ink text-lg placeholder:text-mute focus:outline-none focus:border-link focus:ring-2 focus:ring-link/20 transition-all"
            autofocus
          />
          <button 
            type="submit"
            class="absolute right-2 top-1/2 -translate-y-1/2 h-10 px-4 rounded-pill bg-link text-white text-sm font-semibold hover:bg-link-hover transition-all"
          >
            Search
          </button>
        </form>
      </div>

      {query && movies.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:gap-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
          {movies.map(movie => <MovieCardAstro movie={movie} />)}
        </div>
      ) : query ? (
        <div class="py-24 text-center">
          <p class="text-lg text-body">No movies found matching "{query}".</p>
          <a href="/search" class="mt-4 inline-block text-link font-medium hover:underline">Try a different search</a>
        </div>
      ) : null}
    </div>
  </main>
  <Footer />
</Layout>
