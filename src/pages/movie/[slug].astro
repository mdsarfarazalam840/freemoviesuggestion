---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SuggestedMoviesMarquee from '../../components/SuggestedMoviesMarquee.tsx';
import { getMovieBySlug, getRegionFilteredRecommendations } from '../../services/movieService';
import { MOOD_EMOJI, MOOD_DESCRIPTION } from '../../data/movies';
import type { MoodTag } from '../../data/movies';

export const prerender = false;

const { slug } = Astro.params;
let movie: any = null;
let recommendations: any[] = [];
try {
  movie = slug ? await getMovieBySlug(slug) : null;
} catch (error) {
  console.error('[movie/[slug].astro] Error:', error);
  Astro.response.status = 500;
}

if (!movie) {
  Astro.response.status = 404;
}

// Redirect if the slug doesn't match the movie's official slug (e.g. missing ID suffix)
if (movie && movie.slug !== slug) {
  return Astro.redirect(`/movie/${movie.slug}`);
}

if (movie) {
  try {
    recommendations = await getRegionFilteredRecommendations(movie, 8);
  } catch (error) {
    console.error('[movie/[slug].astro] Recommendations error:', error);
  }
}

// Fallback poster (matches MovieCard.astro) for movies with an empty/broken thumbnail
const PLACEHOLDER_SVG = 'data:image/svg+xml,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="300" height="450" viewBox="0 0 300 450"><rect fill="%23334155" width="300" height="450"/><text x="150" y="210" font-family="sans-serif" font-size="18" font-weight="bold" fill="%23F5C518" text-anchor="middle">No Image</text></svg>');
const posterSrc = (movie?.thumbnail && movie.thumbnail.trim()) || PLACEHOLDER_SVG;
---

<Layout title={movie?.title || 'Movie Not Found'} description={movie?.description || 'The requested movie could not be found.'}>
  {movie && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Movie",
      "name": movie.title,
      "description": movie.description,
      "image": movie.thumbnail || undefined,
      "datePublished": movie.releaseYear.toString(),
      "genre": movie.genres,
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": movie.rating,
        "bestRating": "10",
        "worstRating": "1",
        "ratingCount": "100" // Placeholder as TMDB rating count isn't in our schema yet
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": Astro.site
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Movies",
          "item": new URL('/movies', Astro.site)
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": movie.title,
          "item": new URL(Astro.url.pathname, Astro.site)
        }
      ]
    })} />
  )}
  <Navbar />
  <main class="bg-canvas min-h-screen">
    {movie ? (
    <>
    <!-- Hero Banner - 2026 Cinematic -->
    <div class="relative min-h-[380px] sm:min-h-[500px] md:min-h-[650px] w-full overflow-hidden">
      <img
        src={posterSrc}
        alt={movie.title}
        onerror={`this.onerror=null;this.src='${PLACEHOLDER_SVG}'`}
        class="absolute inset-0 h-full w-full object-cover blur-3xl opacity-40 scale-125 transition-transform duration-[20s] ease-linear animate-pulse"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-canvas via-canvas/40 to-transparent"></div>
      
      <div class="relative mx-auto max-w-7xl px-4 h-full flex items-center md:items-end pb-20 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row gap-12 items-center md:items-end w-full">
          <div class="w-44 sm:w-56 md:w-72 flex-shrink-0 shadow-premium-dark rounded-premium overflow-hidden border-2 border-white/10 bg-canvas group">
             <img
              src={posterSrc}
              alt={movie.title}
              onerror={`this.onerror=null;this.src='${PLACEHOLDER_SVG}'`}
              class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="flex-1 text-center md:text-left">
            <div class="flex items-center justify-center md:justify-start gap-3 mb-6">
               <span class="rounded-pill bg-link px-4 py-1.5 text-xs font-black text-white uppercase tracking-widest shadow-glow">
                {movie.region}
              </span>
              <span class="text-lg font-bold text-mute">{movie.releaseYear}</span>
            </div>
            <h1 class="text-3xl sm:text-5xl lg:text-7xl font-bold tracking-tight text-ink mb-6 drop-shadow-sm break-words">{movie.title}</h1>
            <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 sm:gap-8">
              <div class="flex items-center gap-3">
                <div class="relative flex items-center justify-center">
                  <svg class="w-14 h-14 sm:w-16 sm:h-16 -rotate-90" viewBox="0 0 36 36">
                    <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="2.5" class="text-hairline-strong" />
                    <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-dasharray={`${Math.min(movie.watchScore || 0, 100)} ${100 - Math.min(movie.watchScore || 0, 100)}`} stroke-dashoffset="0" stroke-linecap="round" class="text-link" />
                  </svg>
                  <span class="absolute text-lg sm:text-2xl font-black text-ink">{movie.watchScore || '—'}</span>
                </div>
                <div>
                  <div class="text-xs font-bold uppercase tracking-widest text-mute">WatchScore</div>
                  <div class="text-[10px] text-body">Our Unique Score</div>
                </div>
              </div>
              <div class="flex items-center gap-2 border-l border-hairline pl-4 sm:pl-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-amber-50 dark:bg-amber-900/20">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-amber-500"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <div>
                  <div class="text-lg font-bold text-ink">{movie.rating}<span class="text-xs font-medium text-mute">/10</span></div>
                  <div class="text-[9px] font-bold uppercase tracking-widest text-mute">TMDB</div>
                </div>
              </div>
              <div class="flex gap-2 flex-wrap">
                {movie.genres.map((genre: string) => (
                  <a 
                    href={`/genre/${genre.toLowerCase()}`} 
                    class="text-sm font-bold text-body px-4 py-2 bg-canvas-soft-2 rounded-pill border border-hairline hover:border-link hover:text-link transition-all"
                  >
                    #{genre}
                  </a>
                ))}
              </div>
            </div>
            {movie.moodTags && movie.moodTags.length > 0 && (
              <div class="flex flex-wrap items-center justify-center md:justify-start gap-2 mt-4">
                {movie.moodTags.map((tag: MoodTag) => (
                  <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-pill bg-gradient-to-r from-link/10 to-accent/10 border border-link/20 text-sm font-bold text-ink" title={MOOD_DESCRIPTION[tag]}>
                    {MOOD_EMOJI[tag]} {tag}
                  </span>
                ))}
              </div>
            )}
            <div class="flex gap-2 mt-4 flex-wrap">
              {movie.imdbUrl && (
                <a href={movie.imdbUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-pill bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-amber-800 text-sm font-bold hover:bg-amber-100 dark:hover:bg-amber-900/40 transition-all">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.67 0H5.33C2.38 0 0 2.38 0 5.33v13.34C0 21.62 2.38 24 5.33 24h13.34c2.95 0 5.33-2.38 5.33-5.33V5.33C24 2.38 21.62 0 18.67 0zm-9.4 16.67H6.67V7.33h2.6v9.34zm4.66 0h-2.6v-3.7h2.6c1.03 0 1.87-.84 1.87-1.87v-.72c0-1.04-.84-1.87-1.87-1.87h-4.47v9.34h2.6v-3.35h.5l1.12 3.35h2.76l-1.44-4.1c.7-.33 1.2-1.05 1.2-1.88v-.72c0-1.24-1-2.24-2.23-2.24H13.6v3.42h2.36v.65c0 .34-.28.62-.62.62h-2.24v3.35zm7.5-1.87c0 1.04-.84 1.87-1.87 1.87h-2.1V7.33h2.1c1.03 0 1.87.84 1.87 1.87v5.6z"/></svg>
                  View on IMDB
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10M7 17L17 7"/></svg>
                </a>
              )}
              {movie.rtUrl && (
                <a href={movie.rtUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-pill bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800 text-sm font-bold hover:bg-red-100 dark:hover:bg-red-900/40 transition-all">
                  🍅 Check Rotten Tomatoes
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10M7 17L17 7"/></svg>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Content - 2026 Layout -->
    <section class="py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20">
          <div class="lg:col-span-8">
            <div class="mb-16">
              <h2 class="text-3xl font-bold text-ink mb-8 flex items-center gap-3">
                <span class="h-8 w-1.5 bg-link rounded-full"></span>
                The Storyline
              </h2>
              <p class="text-xl text-body leading-relaxed opacity-90 first-letter:text-5xl first-letter:font-bold first-letter:mr-3 first-letter:float-left first-letter:text-link">
                {movie.description}
              </p>
            </div>

            <h2 class="text-3xl font-bold text-ink mb-4 flex items-center gap-3">
              <span class="h-8 w-1.5 bg-accent rounded-full"></span>
              Experience on Streaming
            </h2>
            <p class="text-sm text-body mb-6">
              Available on <strong class="text-ink">{movie.ottPlatforms.length}</strong> streaming {movie.ottPlatforms.length === 1 ? 'platform' : 'platforms'}
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {movie.ottPlatforms.map((platform: { url: string; logo: string; name: string }) => (
                <div class="flex flex-col gap-3 group">
                  <a 
                    href={platform.url} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="flex items-center justify-between p-6 rounded-premium border border-hairline bg-canvas transition-all hover:border-link hover:shadow-premium group"
                  >
                    <div class="flex items-center gap-4">
                      <div class="h-14 w-14 rounded-premium bg-canvas-soft-2 border border-hairline flex items-center justify-center p-3 shadow-inner">
                        <img src={platform.logo} alt={platform.name} class="max-h-full max-w-full object-contain transition-transform group-hover:scale-110" />
                      </div>
                      <div>
                        <span class="block font-black text-ink">Watch on {platform.name}</span>
                        <span class="text-xs font-bold text-link uppercase tracking-widest">Premium Discovery</span>
                      </div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-hairline-strong group-hover:text-link group-hover:translate-x-1 transition-all"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                  </a>
                  <a 
                    href={`/ott/${platform.name.toLowerCase().replace('+', 'plus').replace(' ', '-')}`}
                    class="text-xs font-bold text-mute hover:text-link transition-colors px-2 flex items-center gap-1"
                  >
                    More {platform.name} Suggestions <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                  </a>
                </div>
              ))}
            </div>
          </div>

          <aside class="lg:col-span-4 space-y-12">
            <div class="rounded-premium border border-hairline p-10 bg-canvas-soft-2 relative overflow-hidden group">
              <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-32 h-32 bg-link/5 rounded-full blur-2xl"></div>
              <h3 class="text-xl font-bold text-ink mb-8 relative">Movie Intelligence</h3>
              <dl class="space-y-8 relative">
                <div class="flex justify-between items-center border-b border-hairline pb-4">
                  <dt class="text-[10px] font-black uppercase tracking-widest text-mute">Release Window</dt>
                  <dd class="text-sm font-bold text-ink">{movie.releaseYear}</dd>
                </div>
                <div class="flex justify-between items-center border-b border-hairline pb-4">
                  <dt class="text-[10px] font-black uppercase tracking-widest text-mute">Origin Region</dt>
                  <dd class="text-sm font-bold text-ink">{movie.region}</dd>
                </div>
                <div class="flex justify-between items-center border-b border-hairline pb-4">
                  <dt class="text-[10px] font-black uppercase tracking-widest text-mute">Genre Spectrum</dt>
                  <dd class="text-sm font-bold text-ink text-right">{movie.genres.join(', ')}</dd>
                </div>
                <div class="flex justify-between items-center border-b border-hairline pb-4">
                  <dt class="text-[10px] font-black uppercase tracking-widest text-mute">WatchScore</dt>
                  <dd class="text-sm font-bold text-ink text-right">
                    {movie.watchScore ? `${movie.watchScore}/100 — ${movie.watchScore >= 90 ? 'Excellent' : movie.watchScore >= 80 ? 'Great' : movie.watchScore >= 70 ? 'Good' : movie.watchScore >= 60 ? 'Fair' : 'Mixed'}` : '—'}
                  </dd>
                </div>
                <div class="flex justify-between items-center border-b border-hairline pb-4">
                  <dt class="text-[10px] font-black uppercase tracking-widest text-mute">Mood</dt>
                  <dd class="text-sm font-bold text-ink text-right">
                    {movie.moodTags && movie.moodTags.length > 0
                      ? movie.moodTags.map((tag: MoodTag) => `${MOOD_EMOJI[tag]} ${tag}`).join(', ')
                      : '—'}
                  </dd>
                </div>
                <div class="flex justify-between items-center border-b border-hairline pb-4">
                  <dt class="text-[10px] font-black uppercase tracking-widest text-mute">OTT Availability</dt>
                  <dd class="text-sm font-bold text-ink text-right">{movie.ottPlatforms.length} {movie.ottPlatforms.length === 1 ? 'platform' : 'platforms'}</dd>
                </div>
                <div class="flex justify-between items-center border-b border-hairline pb-4">
                  <dt class="text-[10px] font-black uppercase tracking-widest text-mute">Reviews</dt>
                  <dd class="text-sm font-bold text-ink text-right">
                    {movie.imdbUrl || movie.rtUrl ? (
                      <span class="flex gap-2">
                        {movie.imdbUrl && <a href={movie.imdbUrl} target="_blank" rel="noopener noreferrer" class="text-amber-600 dark:text-amber-400 hover:underline">IMDB</a>}
                        {movie.rtUrl && <a href={movie.rtUrl} target="_blank" rel="noopener noreferrer" class="text-red-500 dark:text-red-400 hover:underline">RT</a>}
                      </span>
                    ) : '—'}
                  </dd>
                </div>
              </dl>
            </div>
            
            <div class="text-center p-10 border-2 border-dashed border-link/20 rounded-premium bg-link/5">
              <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-full bg-link text-white shadow-glow">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
              </div>
              <p class="text-base font-bold text-ink mb-6 italic leading-relaxed">"Verified Suggestion: This title is trending in the top 1% of community picks this month."</p>
              <div class="flex justify-center -space-x-3">
                {[1,2,3,4,5].map(i => (
                  <div class="h-10 w-10 rounded-full border-2 border-canvas bg-canvas-soft-2 flex items-center justify-center text-mute shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  </div>
                ))}
              </div>
            </div>
          </aside>
        </div>

        {recommendations.length > 0 && (
          <SuggestedMoviesMarquee
            client:visible
            movies={recommendations}
            region={movie.region}
          />
        )}
      </div>
    </section>
    </>
    ) : (
    <div class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center">
      <h1 class="text-6xl font-bold text-ink">404</h1>
      <p class="text-xl text-body mt-4">Movie not found</p>
      <p class="text-body mt-2">This movie hasn't been added to our database yet.</p>
      <a href="/" class="mt-8 px-6 py-3 bg-link text-white rounded-premium font-medium hover:bg-link/90 transition-colors">
        Browse Movies
      </a>
    </div>
    )}
  </main>
  <Footer />
</Layout>
