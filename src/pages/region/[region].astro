---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import MovieCard from '../../components/MovieCard.astro';
import Footer from '../../components/Footer.astro';
import { movies, REGIONS } from '../../data/movies';

export function getStaticPaths() {
  return REGIONS.map(region => ({
    params: { region: region.toLowerCase() },
    props: { region },
  }));
}

const { region } = Astro.props;
const filteredMovies = movies.filter(m => m.region.toLowerCase() === region.toLowerCase());
---

<Layout title={`${region} Movies`} description={`The best ${region} movies selected for you.`}>
  <Navbar />
  <main class="min-h-screen bg-canvas-soft py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <nav class="flex mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center space-x-2 text-xs font-mono uppercase tracking-wider text-mute">
            <li><a href="/" class="hover:text-ink">Home</a></li>
            <li><span class="mx-2">/</span></li>
            <li class="text-ink">Region</li>
          </ol>
        </nav>
        <h1 class="text-4xl font-bold tracking-tight text-ink">{region} Movies<span class="text-link">.</span></h1>
        <p class="mt-4 text-lg text-body max-w-2xl">
          Discover high-quality {region} cinema across all streaming platforms.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
        {filteredMovies.map(movie => <MovieCard movie={movie} />)}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
