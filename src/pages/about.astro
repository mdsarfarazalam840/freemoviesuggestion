---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="About Us"
  description="Learn about Free Movie Suggestion — our mission to help you find your next favorite movie across every OTT platform."
>
  <Navbar />
  <main class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="max-w-none">
      <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl">About Free Movie Suggestion<span class="text-link">.</span></h1>
      <p class="mt-6 text-xl text-body leading-relaxed">
        Free Movie Suggestion was born out of a simple frustration: spending more time looking for a movie than actually watching it.
      </p>
      <p class="mt-6 text-xl text-body leading-relaxed">
        We believe that finding a great story should be as effortless as the entertainment itself. Our engine analyzes trends, ratings, and availability across all major OTT platforms to give you the perfect pick in seconds.
      </p>
      <p class="mt-6 text-xl text-body leading-relaxed">
        Whether you're in the mood for a Bollywood drama, a Hollywood blockbuster, or a Tollywood hit, we've got you covered.
      </p>

      <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2">
        <div class="rounded-premium border border-hairline bg-canvas-soft p-8">
          <h2 class="text-2xl font-semibold text-ink">Our Mission</h2>
          <p class="mt-4 text-body leading-relaxed">To solve streaming fragmentation and help people discover their next favorite story without the friction of searching multiple apps.</p>
        </div>
        <div class="rounded-premium border border-hairline bg-canvas-soft p-8">
          <h2 class="text-2xl font-semibold text-ink">How it Works</h2>
          <p class="mt-4 text-body leading-relaxed">We index content from Netflix, Prime Video, Disney+, Hotstar, and more, providing a unified search and recommendation experience.</p>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
