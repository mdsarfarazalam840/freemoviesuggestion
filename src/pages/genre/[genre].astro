---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import MovieCardReact from '../../components/MovieCard.tsx';
import Footer from '../../components/Footer.astro';
import { getMoviesPage } from '../../services/movieService';
import { GENRES } from '../../data/movies';

export const prerender = false

const { genre } = Astro.params;
const currentGenre = genre || '';
const normalizeGenreSlug = (value = '') => value.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
const genreLabel = GENRES.find((item) => normalizeGenreSlug(item) === normalizeGenreSlug(currentGenre)) || currentGenre.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
const page = Number(Astro.url.searchParams.get('page') || '1');
const pageData = await getMoviesPage({ page, limit: 24, genre: genreLabel });
const filteredMovies = pageData.movies;
const pageHref = (nextPage: number) => nextPage > 1 ? `/genre/${currentGenre}?page=${nextPage}` : `/genre/${currentGenre}`;
---

<Layout title={`${genreLabel} Movies`} description={`Find the best ${genreLabel} movies suggested by our community.`}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": Astro.site
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Genres",
        "item": new URL('/movies#genres', Astro.site)
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": genreLabel,
        "item": new URL(Astro.url.pathname, Astro.site)
      }
    ]
  })} />
  <Navbar />
  <main class="min-h-screen bg-canvas-soft py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <nav class="flex mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center space-x-2 text-xs font-mono uppercase tracking-wider text-mute">
            <li><a href="/" class="hover:text-ink">Home</a></li>
            <li><span class="mx-2">/</span></li>
            <li><a href="/movies" class="hover:text-ink">Movies</a></li>
            <li><span class="mx-2">/</span></li>
            <li class="text-ink">Genre</li>
          </ol>
        </nav>
        <h1 class="text-4xl font-bold tracking-tight text-ink">{genreLabel} Movies<span class="text-link">.</span></h1>
        <p class="mt-4 text-lg text-body max-w-2xl">
          Explore our collection of {genreLabel.toLowerCase()} movies available on various streaming platforms.
        </p>
      </div>

      {filteredMovies.length > 0 ? (
        <>
          <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
            {filteredMovies.map(movie => <MovieCardReact client:visible movie={movie} />)}
          </div>
          {pageData.totalPages > 1 && (
            <nav class="mt-10 flex items-center justify-between border-t border-hairline pt-6" aria-label="Pagination">
              <a href={pageHref(pageData.page - 1)} class:list={['text-sm font-medium text-link hover:underline', pageData.page <= 1 && 'pointer-events-none opacity-40']}>Previous</a>
              <span class="text-sm text-mute">Page {pageData.page} of {pageData.totalPages}</span>
              <a href={pageHref(pageData.page + 1)} class:list={['text-sm font-medium text-link hover:underline', pageData.page >= pageData.totalPages && 'pointer-events-none opacity-40']}>Next</a>
            </nav>
          )}
        </>
      ) : (
        <div class="py-24 text-center bg-canvas rounded-premium border border-hairline shadow-premium">
          <p class="text-lg text-body">No movies found in the {genreLabel} genre yet.</p>
          <a href="/movies" class="mt-4 inline-block text-link font-medium hover:underline">Explore all movies</a>
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>
