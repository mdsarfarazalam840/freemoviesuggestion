---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import MovieCard from '../../components/MovieCard.astro';
import Footer from '../../components/Footer.astro';
import { getAllMovies } from '../../services/movieService';

export const prerender = false

const { genre } = Astro.params;
const movies = await getAllMovies();
const filteredMovies = movies.filter(m => m.genres.some(g => g.toLowerCase() === genre?.toLowerCase()));
---

<Layout title={`${genre} Movies`} description={`Find the best ${genre} movies suggested by our community.`}>
  <Navbar />
  <main class="min-h-screen bg-canvas-soft py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <nav class="flex mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center space-x-2 text-xs font-mono uppercase tracking-wider text-mute">
            <li><a href="/" class="hover:text-ink">Home</a></li>
            <li><span class="mx-2">/</span></li>
            <li><a href="/movies" class="hover:text-ink">Movies</a></li>
            <li><span class="mx-2">/</span></li>
            <li class="text-ink">Genre</li>
          </ol>
        </nav>
        <h1 class="text-4xl font-bold tracking-tight text-ink">{genre} Movies<span class="text-link">.</span></h1>
        <p class="mt-4 text-lg text-body max-w-2xl">
          Explore our collection of {genre.toLowerCase()} movies available on various streaming platforms.
        </p>
      </div>

      {filteredMovies.length > 0 ? (
        <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
          {filteredMovies.map(movie => <MovieCard movie={movie} />)}
        </div>
      ) : (
        <div class="py-24 text-center bg-canvas rounded-vercel-lg border border-hairline shadow-vercel">
          <p class="text-lg text-body">No movies found in the {genre} genre yet.</p>
          <a href="/movies" class="mt-4 inline-block text-link font-medium hover:underline">Explore all movies</a>
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>
