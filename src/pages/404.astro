---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Not Found">
  <div class="flex flex-col items-center justify-center min-h-screen p-4 text-center overflow-hidden">
    <div id="container" class="space-y-4">
      <h1 id="title" class="text-9xl font-bold">404</h1>
      <p id="message" class="text-2xl">Oops! The page you're looking for doesn't exist.</p>
      <a id="link" href="/" class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
        Go Home
      </a>
    </div>
  </div>

  <script>
    import { gsap } from 'gsap';
    
    // GSAP animation
    const tl = gsap.timeline();
    tl.fromTo('#title', { scale: 0.5, opacity: 0 }, { scale: 1, opacity: 1, duration: 1, ease: 'back.out(1.7)' })
      .fromTo('#message', { y: 20, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5 }, '-=0.5')
      .fromTo('#link', { y: 20, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5 }, '-=0.3');
  </script>
</Layout>
